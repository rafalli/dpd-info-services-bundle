{
    "name": "rafalli/dpd-info-services-bundle",
    "description": "Symfony 7.4 Bundle integrating DPD InfoServices SOAP API for tracking packages",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-soap": "*",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/translation": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/phpunit-bridge": "^6.4 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Rafalli\\DpdInfoServicesBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rafalli\\DpdInfoServicesBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    }
}
